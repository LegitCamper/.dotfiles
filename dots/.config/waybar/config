{
    "height": 46,
    "modules-left": [
        "sway/workspaces",
        "hyprland/workspaces",
        "niri/workspaces",
        "custom/podmantoolbox",
    ],
    "modules-center": [
        "clock" ,
        "clock#date" ,
    ],
    "modules-right": [
		"backlight",
        "battery",
        "pulseaudio",
        "pulseaudio#microphone",
        "bluetooth",
        "network",
        "tray",
    ],
    "tray": {
        "spacing": 10
    },
    "hyprland/workspaces": {
        "format": "{icon}",
        "on-click": "activate",
    },
    "niri/workspaces": {
        "format": "{icon}",
	    "format-icons": {
	    	"browser": "1",
	    	"terminal": "2",
	    	"chat": "3",
	    	"steam": "4",
	    	"games": "5",
	    	"other": "6",
	    	"other1": "7",
	    	"other2": "8",
	    	"other3": "9",
	    	"bitwarden": "10",
	    	"default": "ΎΕΣ"
	    }
    },
    "sway/workspaces": {
        "disable-scroll": true,
        "all-outputs": true,
        "format": "{icon}",
        "on-click": "activate",
    },
    "custom/podmantoolbox": {
        "exec": "~/.config/waybar/scripts/podman.sh -c arch-toolbox-latest",
        "format": "≤░οφ {}",
        "interval": 2,
        "on-click": "~/.config/waybar/scripts/podman.sh -c arch-toolbox-latest toggle"
    },
    "clock": {
		"format": "{:%I:%M %p}",
    },
    "clock#date": {
        "format": "{:%m/%d/%Y}",
    },
    "backlight": {
        "format": "{icon} {percent}%",
        "format-icons": [
            "ΌΟΞ",
            "ΌΠΥ",
            "ΌΠΣ",
            "ΌΠΠ",
            "ΌΠΟ",
            "ΌΠΞ",
            "ΌΠΛ",
            "ΌΠΙ",
            "ΌΟδ"
        ]
    },
    "battery": {
        "states": {
            "warning": 30,
            "critical": 15
        },
        "format": "{icon} {capacity}%",
        "format-charging": "≤░ΓΕ {capacity}%",
        "format-plugged": "ΎΘο {capacity}%",
        "format-icons": [
            "ΎΚΕ",
            "ΎΚΔ",
            "ΎΚΓ",
            "ΎΚΒ",
            "ΎΚΑ"
        ],
    },
    "pulseaudio": {
        "format": "{icon} {volume}%",
        "tooltip": false,
        "format-muted": "ΎΑο Muted",
        "on-click": "pamixer -t",
        "on-scroll-up": "pamixer -i 5",
        "on-scroll-down": "pamixer -d 5",
        "scroll-step": 5,
        "format-icons": {
            "headphone": "ΎΑξ",
            "hands-free": "ΎΑξ",
            "headset": "ΎΑξ",
            "phone": "ΎΓΧ",
            "portable": "ΎΓΧ",
            "default": ["ΎΑο", "ΎΑπ", "ΎΑρ"]
        }
    },
    "pulseaudio#microphone": {
        "format": "{format_source}",
        "format-source": "ΎΕ░ {volume}%",
        "format-source-muted": "ΎΕ▒ Muted",
        "on-click": "pamixer --default-source -t",
        "on-scroll-up": "pamixer --default-source -i 5",
        "on-scroll-down": "pamixer --default-source -d 5",
        "scroll-step": 5
    },
    "network": {
        "format-wifi": " ΎΘτ {essid} {signalStrength}%",
        "format-ethernet": " ≤░▒Υ {ifname}: {ipaddr}/{cidr}",
        "format-linked": "{ifname} (No IP)",
        "format-disconnected": "Disconnected έγι",
    },
    "bluetooth": {
        "format": "ΎΛΦ {status}",
        "format-disabled": "", // an empty format will hide the module
        "format-connected": "ΎΛΦ {num_connections}",
        "tooltip-format": "{device_alias}",
        "tooltip-format-connected": "ΎΛΦ {device_enumerate}",
        "tooltip-format-enumerate-connected": "{device_alias}"
    },
    "custom/launch_wlogout": {
        "format": "έΠ╗  ",
        "on-click": "wlogout",
        "tooltip": false
    }
}
